# ======================
# Supabase Configuration
# ======================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
# Direct connection (may fail on Windows due to IPv6-only DNS)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres
# Alternative: Supabase connection pooler (IPv4, get URL from Supabase Dashboard > Settings > Database)
# DATABASE_URL=postgresql+asyncpg://postgres.your-project:password@aws-0-REGION.pooler.supabase.com:6543/postgres

# ======================
# MetaTrader 5
# ======================
MT5_LOGIN=your-login-number
MT5_PASSWORD=your-password
MT5_SERVER=MetaQuotes-Demo

# ======================
# Redis
# ======================
REDIS_URL=redis://localhost:6379/0

# ======================
# OpenAI (for AI Analysis)
# ======================
OPENAI_API_KEY=sk-your-key

# ======================
# Application
# ======================
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000
SECRET_KEY=generate-a-random-secret-key

# ======================
# Risk Management
# ======================
MAX_DAILY_LOSS_PERCENT=3.0
MAX_DRAWDOWN_PERCENT=10.0
MAX_TRADES_PER_HOUR=10
DEFAULT_RISK_PER_TRADE=1.0
